{
  "name": "@noryx/react",
  "version": "0.1.0",
  "description": "React bindings for Noryx primitives and workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edujbarrios/Noryx.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@noryx/core": "workspace:*",
    "@noryx/runtime": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "typescript": "^5.7.3"
  }
}
