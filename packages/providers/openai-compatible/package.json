{
  "name": "@noryx/openai-compatible",
  "version": "0.1.0",
  "description": "OpenAI-compatible provider adapter for Noryx.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edujbarrios/Noryx.git",
    "directory": "packages/providers/openai-compatible"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@noryx/core": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
